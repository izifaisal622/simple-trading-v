# ─── Simple Trading V — Secrets Template ──────────────────────────────────────
# Salin file ini menjadi secrets.toml lalu isi dengan key asli kamu.
# File secrets.toml TIDAK akan ter-push ke GitHub (.gitignore).
#
# Cara pakai:
#   1. Copy file ini → secrets.toml (di folder yang sama)
#   2. Ganti nilai di bawah dengan key asli
#   3. Restart Streamlit

# Gemini API Key — dapatkan di https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "isi_gemini_api_key_kamu_disini"
